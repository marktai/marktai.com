# Namecheap API credentials for acme.sh DNS challenge (wildcard certs)
# 1. Enable API at: https://ap.www.namecheap.com/settings/tools/apiaccess/
# 2. Whitelist your server's public IP in Namecheap API settings
# 3. Copy this file to .env and fill in your values

NAMECHEAP_USERNAME=your_namecheap_username
NAMECHEAP_API_KEY=your_api_key
NAMECHEAP_SOURCEIP=your_server_public_ip
